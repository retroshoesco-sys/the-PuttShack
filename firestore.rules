rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Sessions
    match /sessions/{sessionId} {
      function isValidSession(data) {
        return data.keys().hasAll(['name', 'status', 'createdAt']) && 
               data.keys().size() == 3 &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
               data.status in ['active', 'finished'] &&
               data.createdAt == request.time;
      }

      allow list: if isSignedIn();
      allow get: if isSignedIn() && isValidId(sessionId);
      allow create: if isSignedIn() && isValidSession(incoming());
      allow update: if isSignedIn() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        incoming().status in ['active', 'finished']
      );

      // Players Subcollection
      match /players/{playerId} {
        function isValidPlayer(data) {
          return data.keys().hasAll(['name', 'score', 'color', 'joinedAt']) &&
                 data.keys().size() == 4 &&
                 data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
                 data.score is int &&
                 data.color is string && data.color.size() <= 100 &&
                 data.joinedAt == request.time;
        }

        allow list: if isSignedIn();
        allow get: if isSignedIn() && isValidId(playerId);
        allow create: if isSignedIn() && isValidPlayer(incoming());
        allow update: if isSignedIn() && (
          // Action: Update Score
          (incoming().diff(existing()).affectedKeys().hasOnly(['score']) &&
           incoming().score is int &&
           incoming().score >= 0)
        );
      }
    }
  }
}
